# PostgreSQL Main Configuration
POSTGRES_VERSION=16
POSTGRES_USER=engineer
POSTGRES_PASSWORD=engineering_secret
POSTGRES_DB=production_db
POSTGRES_PORT=5432

# Replication & HA
REPLICATION_USER=replicator
REPLICATION_PASSWORD=replicator_secret
SYNCHRONOUS_COMMIT=on
MAX_WAL_SENDERS=10
WAL_LEVEL=replica

# Citus Configuration
CITUS_USER=citus
CITUS_PASSWORD=citus
CITUS_DB=citus
CITUS_VERSION=11.0

# Kubernetes
NAMESPACE=postgres
STORAGE_CLASS=fast-ssd
REPLICA_COUNT=3

# Backup Configuration
BACKUP_DIR=./backups
WAL_DIR=./backups/wal_archive
RESTORE_DIR=./restore_data
BACKUP_RETENTION_DAYS=30
PITR_TARGET_TIME=2024-01-01 00:00:00

# Monitoring & Observability
PROMETHEUS_RETENTION=30d
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# pgAdmin
PGADMIN_EMAIL=admin@engineering.com
PGADMIN_PASSWORD=admin

# Benchmarking
PGBENCH_SCALE=100
PGBENCH_CLIENTS=50
PGBENCH_WORKERS=4
PGBENCH_DURATION=600

# Vector Search
PGVECTOR_DIMENSION=1536
HNSW_M=16
HNSW_EF_CONSTRUCTION=64

# Development
DEBUG=false
LOG_LEVEL=INFO
